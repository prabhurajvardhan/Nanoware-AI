{
  "entities": {
    "ContactRequest": {
      "title": "Contact Request",
      "description": "A submission from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "projectType": { "type": "string" },
        "budget": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "archived"] },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["name", "email", "company", "projectType", "budget", "description", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrator user with access to view requests.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A project belonging to a client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "name", "status", "createdAt"]
    },
    "ProjectStep": {
      "title": "Project Step",
      "description": "A step within a project timeline.",
      "type": "object",
      "properties": {
        "stepName": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "previewLink": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["stepName", "description", "status", "order", "createdAt"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Activity updates for a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["projectId", "message", "createdAt"]
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/ContactRequest" },
      "description": "Stores user submitted contact requests."
    },
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Stores admin privileges mapping."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores client projects."
    },
    "/projects/{projectId}/steps/{stepId}": {
      "schema": { "$ref": "#/entities/ProjectStep" },
      "description": "Stores steps or stages for a project."
    },
    "/projects/{projectId}/activities/{activityId}": {
      "schema": { "$ref": "#/entities/ActivityLog" },
      "description": "Activity feed for the project."
    }
  }
}
